# Copy to .env.local for local experiments (never commit real secrets).

# GitHub Pages: set the same value as the SITE_PASSWORD repository secret in CI.
# Leave unset locally to skip the password screen during development.
# VITE_SITE_PASSWORD=

# Vite public path. For https://user.github.io/my-repo/ use:
# VITE_BASE_PATH=/my-repo/
# Local dev: omit or use /
# VITE_BASE_PATH=/

# Contact form mailto recipient (optional)
# VITE_CONTACT_EMAIL=your-team@company.com

# Optional production endpoint for “Live URL” in the review console (GET with `?url=` encoded URL).
# Must return JSON: { "html": "<!DOCTYPE html>...", "finalUrl": "https://..." }.
# Local `npm run dev` uses `/api/fetch-page` automatically and does not need this.
# VITE_PAGE_FETCH_PROXY=https://your-worker.example.dev/fetch
